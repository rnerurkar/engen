    "team": "Policy Platform Engineering",
    "lob": "Policy Administration",
    "current_host": "vSphere on-prem (DC-West, 6 VMs behind NetScaler)",
    "business_criticality": "Tier 2",
    "data_classification": "Confidential (PII)",
    "compliance_regimes": [
      "SOX",
      "internal data-protection standard"
    ]
  },
  "modernization_scope": {
    "integrations_in_scope": [
      "INT-001",
      "INT-002",
      "INT-003",
      "INT-004"
    ],
    "integrations_out_of_scope": [],
    "target_aws_account": "522333444555 (policy-prod)",
    "target_region_primary": "us-east-1",
    "target_region_dr": "us-west-2",
    "cross_cloud_dependencies": [
      "Apigee on GCP enterprise-apigee-prod (rating API)"
    ]
  },
  "integrations": [
    {
      "id": "INT-001",
      "name": "Policy admin UI",
      "functional_categories": [
        "spa_internal_facing"
      ],
      "current_state": {
        "Protocol": "HTTPS",
        "Transport": "server postbacks (ASPX)",
        "Auth": "Windows Integrated Auth (Kerberos)",
        "Payload": "HTML + ViewState",
        "Stack": "ASP.NET WebForms 4.8, IIS 10",
        "SLA": "p95 < 2.5s, 20 RPS peak",
        "Criticality": "Tier 2",
        "Failure today": "ViewState error -> session loss"
      },
      "target_intent": {
        "Preserve": "same navigation map, same role-gated screens",
        "Downtime": "20 min (after-hours)",
        "Regression": "p95 <= 3s first week",
        "Reject": "no postback model"
      },
      "dependencies": "INT-002",
      "r_factor": "Rewrite",
      "cutover_strategy": "Big-bang",
      "validation_gates": "Playwright regression 100%; synthetic p95 < 3s"
    },
    {
      "id": "INT-002",
      "name": "Policy rules + service tier",
      "functional_categories": [
        "app_to_app_internal"
      ],
      "current_state": {
        "Protocol": "HTTPS SOAP",
        "Auth": "WS-Security, internal AD",
        "Payload": "SOAP/XML (policy.wsdl)",
        "Stack": ".NET WCF 4.8, SQL Server 2017",
        "SLA": "p95 < 800ms, 20 RPS peak",
        "Criticality": "Tier 2",
        "Failure today": "SOAP fault -> UI error banner"
      },
      "target_intent": {
        "Preserve": "behavioural parity of policy lifecycle transitions; SQL Server retained on-prem (out of scope)",
        "Downtime": "20 min",
        "Regression": "+75ms p95",
        "Reject": "no business logic in the SPA"
      },
      "dependencies": "none - anchors cutover",
      "r_factor": "Rewrite",
      "cutover_strategy": "Strangler-fig",
      "validation_gates": "transition-parity harness (shadow 7 days, diff < 0.1%)",
      "coexistence": "BFF -> on-prem SQL Server via VPN (DB retained, +30ms)"
    },
    {
      "id": "INT-003",
      "name": "Rating service (cross-cloud)",
      "functional_categories": [
        "app_to_app_external",
        "app_to_app_cross_cloud",
        "sync_request_response"
      ],
      "current_state": {
        "Protocol": "HTTPS REST",
        "Auth": "API key (header) to on-prem rating engine",
        "Payload": "/docs/rating-v3.openapi.yaml",
        "Stack": "internal rating engine, mTLS",
        "SLA": "p95 < 1.2s, 8 RPS peak",
        "Criticality": "Tier 2",
        "Failure today": "fallback to last-good quote (cached)"
      },
      "target_intent": {
        "Preserve": "same rating OpenAPI v3, same idempotency keys, same cache-fallback semantics",
        "Downtime": "0 min",
        "Regression": "+120ms p95 cross-cloud",
        "Reject": "no AWS API Gateway (standard is Apigee)"
      },
      "dependencies": "independent after Apigee provisioned",
      "r_factor": "Replatform",
      "cutover_strategy": "Blue-green",
      "validation_gates": "parity validator (shadow 10 days, diff < 0.1%); latency <= +120ms",
      "cross_cloud": {
        "Source": "on-prem rating engine, DC-West",
        "Target": "GCP Apigee enterprise-apigee-prod",
        "Latency budget": "120ms p95 added",
        "Transit": "AWS PrivateLink -> GCP PSC -> Apigee (per ADR-019)"
      },
      "coexistence": "on-prem rating + Apigee proxy in parallel during soak"
    },
    {
      "id": "INT-004",
      "name": "Document print feed",
      "functional_categories": [
        "app_to_app_external",
        "file_transfer_external"
      ],
      "current_state": {
        "Protocol": "SFTP",
        "Transport": "batch file drop to external print vendor",
        "Auth": "SSH key",
        "Payload": "fixed-width + PDF bundle",
        "Stack": "Windows scheduled task + WinSCP",
        "SLA": "nightly batch, 50k docs",
        "Criticality": "Tier 3",
        "Failure today": "retry next window; ops paged on 2nd failure"
      },
      "target_intent": {
        "Preserve": "same file format, same vendor SFTP endpoint, same nightly SLA",
        "Downtime": "1 window",
        "Regression": "none",
        "Reject": "no change to vendor contract"
      },
      "dependencies": "after INT-002",
      "r_factor": "Replatform",
      "cutover_strategy": "Dual-run",
      "validation_gates": "3-night manifest diff = 0; checksum match",
      "coexistence": "vendor receives from one source per night (manifest reconciliation)"
    }
  ],
