      "name": "Collections engine",
      "functional_categories": [
        "data_pipeline",
        "app_to_app_internal"
      ],
      "current_state": {
        "Protocol": "in-DB (PL/SQL)",
        "Transport": "scheduled DBMS_SCHEDULER jobs",
        "Auth": "DB roles",
        "Payload": "PL/SQL packages over Oracle 19c",
        "Stack": "PL/SQL batch, Oracle 19c",
        "SLA": "hourly + nightly dunning runs",
        "Criticality": "Tier 2",
        "Failure today": "job rerun; ops paged"
      },
      "target_intent": {
        "Preserve": "same dunning rules + aging buckets + ledger postings; Oracle retained on-prem (out of scope)",
        "Downtime": "1 run window",
        "Regression": "+5% run time acceptable",
        "Reject": "no business logic left in DB triggers"
      },
      "dependencies": "none - anchors",
      "r_factor": "Rewrite",
      "cutover_strategy": "Dual-run",
      "validation_gates": "5-cycle ledger parity (diff = 0); aging-bucket reconciliation 100%",
      "coexistence": "ledger written by one engine per cycle (run-token lock)"
    },
    {
      "id": "INT-003",
      "name": "Payment gateway",
      "functional_categories": [
        "app_to_app_external",
        "sync_request_response"
      ],
      "current_state": {
        "Protocol": "HTTPS REST",
        "Auth": "API key + mTLS to external PSP",
        "Payload": "/docs/psp-v2.openapi.yaml (tokenized PAN)",
        "Stack": "PL/SQL + UTL_HTTP",
        "SLA": "p95 < 1.2s, 10 RPS peak",
        "Criticality": "Tier 2",
        "Failure today": "retry; queue for next cycle"
      },
      "target_intent": {
        "Preserve": "same PSP contract, tokenization unchanged, PCI scope minimized",
        "Downtime": "0 min",
        "Regression": "none",
        "Reject": "no PAN at rest outside the PSP token vault"
      },
      "dependencies": "after INT-002",
      "r_factor": "Retain",
      "cutover_strategy": "Strangler-fig",
      "validation_gates": "PCI scope review pass; contract tests green; settlement reconciliation = expected",
      "coexistence": "one caller per transaction; idempotency key reused"
    },
    {
      "id": "INT-004",
      "name": "Dunning notifications",
      "functional_categories": [
        "app_to_app_internal",
        "event_driven_async"
      ],
      "current_state": {
        "Protocol": "JMS",
        "Transport": "IBM MQ (DUN.NOTIFY)",
        "Auth": "TLS + channel cert",
        "Payload": "/docs/dun-notify-v1.json",
        "Stack": "PL/SQL AQ -> MQ bridge",
        "SLA": "300 msg/min, 3000/min peak",
        "Criticality": "Tier 3",
        "Failure today": "backoff; spill to table"
      },
      "target_intent": {
        "Preserve": "at-least-once, contract unchanged",
        "Downtime": "0 min",
        "Regression": "none",
        "Reject": "no SNS"
