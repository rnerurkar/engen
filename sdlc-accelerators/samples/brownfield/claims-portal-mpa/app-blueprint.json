{
  "metadata": {
    "name": "ClaimsPortal-MPA",
    "version": "1.0.0",
    "archetype": "brownfield-modernization",
    "description": "Refactor a server-rendered JSP/Spring-MVC claims portal (MPA) into an Angular SPA + Spring Boot BFF on ECS Fargate, preserving SSO, REST contracts, the cross-cloud domain API, and the async notify stream.",
    "team": "Claims Platform Engineering",
    "lob": "Claims",
    "current_host": "vSphere on-prem (DC-East cluster, 4 VMs behind F5 LTM)",
    "business_criticality": "Tier 2",
    "data_classification": "Confidential (PII)",
    "compliance_regimes": [
      "SOX",
      "internal data-protection standard"
    ]
  },
  "modernization_scope": {
    "integrations_in_scope": [
      "INT-001",
      "INT-002",
      "INT-003",
      "INT-004"
    ],
    "integrations_out_of_scope": [],
    "target_aws_account": "411222333444 (claims-prod)",
    "target_region_primary": "us-east-1",
    "target_region_dr": "us-west-2",
    "cross_cloud_dependencies": [
      "Apigee on GCP enterprise-apigee-prod"
    ]
  },
  "integrations": [
    {
      "id": "INT-001",
      "name": "UI rendering",
      "functional_categories": [
        "spa_internal_facing"
      ],
      "current_state": {
        "Protocol": "HTTPS",
        "Transport": "server-rendered HTML (JSP)",
        "Auth": "SAML SSO via on-prem Ping Federate (session cookie)",
        "Payload": "HTML pages",
        "Stack": "Tomcat 9 + Spring MVC 5 + JSP",
        "SLA": "p95 < 2s, 30 RPS peak",
        "Criticality": "Tier 2",
        "Failure today": "blank page, full outage"
      },
      "target_intent": {
        "Preserve": "same URL paths, same SSO experience",
        "Downtime": "15 min (after-hours)",
        "Regression": "p95 <= 2.5s first week",
        "Reject": "no CSR for /print/* pages"
      },
      "dependencies": "INT-002",
      "r_factor": "Refactor",
      "cutover_strategy": "Big-bang",
      "validation_gates": "Selenium suite 100%; synthetic p95 < 2.5s"
    },
    {
      "id": "INT-002",
      "name": "Server-side application logic",
      "functional_categories": [
        "app_to_app_internal"
      ],
      "current_state": {
        "Protocol": "HTTPS REST",
        "Auth": "SAML session, internal AD",
        "Payload": "JSON (/docs/openapi-v3.yaml)",
        "Stack": "Spring MVC 5, Spring Data JPA, Oracle 19c",
        "SLA": "p95 < 500ms, 30 RPS peak",
        "Criticality": "Tier 2",
        "Failure today": "5xx to UI"
      },
      "target_intent": {
        "Preserve": "same REST contract /api/v1/*, Oracle retained on-prem (out of scope)",
        "Downtime": "15 min (paired with INT-001)",
        "Regression": "+50ms p95",
        "Reject": "no Lambda (sustained traffic)"
      },
      "dependencies": "none - anchors cutover",
      "r_factor": "Refactor",
      "cutover_strategy": "Strangler-fig",
      "validation_gates": "API replay 5000 requests, p95 < 600ms",
      "coexistence": "BFF -> on-prem Oracle (DB retained, +25ms hop)"
    },
    {
      "id": "INT-003",
      "name": "Domain API consumption",
      "functional_categories": [
        "app_to_app_external",
        "app_to_app_cross_cloud",
        "sync_request_response"
      ],
      "current_state": {
        "Protocol": "HTTPS REST",
        "Auth": "OAuth2 client_credentials via APIC, mTLS to APIC edge",
        "Payload": "/docs/domain-api-v2.openapi.yaml",
        "Stack": "Spring RestTemplate, APIC SDK 5.x",
        "SLA": "p95 < 1s, 12 RPS peak",
        "Criticality": "Tier 2",
        "Failure today": "circuit breaker -> cached read-only view"
      },
      "target_intent": {
        "Preserve": "same OpenAPI v2, same OAuth flow, same circuit-breaker semantics",
        "Downtime": "0 min (parallel gateway swap)",
        "Regression": "+100ms p95 cross-cloud hop",
        "Reject": "no AWS API Gateway (standard is Apigee)"
      },
      "dependencies": "independent of INT-001/002 after Apigee provisioned",
      "r_factor": "Replatform",
      "cutover_strategy": "Blue-green",
      "validation_gates": "parity validator (shadow 14 days, diff < 0.1%); latency <= +100ms",
      "cross_cloud": {
        "Source": "on-prem APIC, DC-East",
        "Target": "GCP Apigee enterprise-apigee-prod",
        "Latency budget": "100ms p95 added",
        "Transit": "AWS PrivateLink -> GCP PSC -> Apigee (per ADR-019)"
      },
      "coexistence": "APIC + Apigee live in parallel during soak"
    },
    {
      "id": "INT-004",
      "name": "Async messaging",
      "functional_categories": [
        "app_to_app_internal",
        "event_driven_async"
      ],
      "current_state": {
        "Protocol": "JMS",
        "Transport": "IBM MQ (CLAIMS.OUT.NOTIFY)",
        "Auth": "TLS + MQ channel cert",
        "Payload": "/docs/notify-event-v1.json",
        "Stack": "Spring JMS + IBM MQ client 9.1",
        "SLA": "500 msg/min sustained, 5000/min peak",
        "Criticality": "Tier 2",
        "Failure today": "backoff; spill to file + replay after 5 min"
      },
      "target_intent": {
        "Preserve": "at-least-once, existing message contract unchanged",
        "Downtime": "0 min (dual-publish covers)",
        "Regression": "none",
        "Reject": "no SNS (downstream wants point-to-point)"
      },
      "dependencies": "after INT-002 (BFF must exist to publish)",
      "r_factor": "Refactor",
      "cutover_strategy": "Dual-publish",
      "validation_gates": "24h load test; SQS publish p95 < 50ms",
      "coexistence": "downstream deduplicates by event_id (ticket DSN-4471)"
    }
  ],
  "services": [
    {
      "name": "claims-portal-mpa-ui-rendering",
