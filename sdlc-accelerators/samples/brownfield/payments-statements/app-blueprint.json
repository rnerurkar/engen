{
  "metadata": {
    "name": "PaymentsStatements-MainframeFront",
    "version": "1.0.0",
    "archetype": "brownfield-modernization",
    "description": "Replatform a mainframe-fronted statements + payment-posting service into containerized Spring Boot APIs on ECS Fargate, preserving the host statement contract, moving PDF rendering off batch, and routing payment posting through cross-cloud fraud scoring.",
    "team": "Payments Platform Engineering",
    "lob": "Deposits & Payments",
    "current_host": "On-prem WebSphere fronting mainframe (DC-East), 4 nodes",
    "business_criticality": "Tier 1",
    "data_classification": "Restricted (PCI + PII)",
    "compliance_regimes": [
      "PCI-DSS",
      "SOX",
      "GLBA"
    ]
  },
  "modernization_scope": {
    "integrations_in_scope": [
      "INT-001",
      "INT-002",
      "INT-003",
      "INT-004"
    ],
    "integrations_out_of_scope": [],
    "target_aws_account": "744555666777 (payments-prod)",
    "target_region_primary": "us-east-1",
    "target_region_dr": "us-west-2",
    "cross_cloud_dependencies": [
      "Apigee on GCP enterprise-apigee-prod (fraud scoring)"
    ]
  },
  "integrations": [
    {
      "id": "INT-001",
      "name": "Statement retrieval API",
      "functional_categories": [
        "app_to_app_internal",
        "sync_request_response"
      ],
      "current_state": {
        "Protocol": "MQ request/reply",
        "Transport": "IBM MQ to CICS/COBOL (STMT.GET)",
        "Auth": "channel cert",
        "Payload": "copybook -> JSON adapter",
        "Stack": "WebSphere MDB + COBOL",
        "SLA": "p95 < 1.5s, 40 RPS peak",
        "Criticality": "Tier 1",
        "Failure today": "timeout -> retry; cached last statement"
      },
      "target_intent": {
        "Preserve": "same statement schema, same masking of PAN, host call retained",
        "Downtime": "0 min",
        "Regression": "+80ms p95",
        "Reject": "no PAN in logs or traces"
      },
      "dependencies": "none - anchors",
      "r_factor": "Replatform",
      "cutover_strategy": "Strangler-fig",
      "validation_gates": "field-level parity (shadow 10 days); PAN-masking audit 100%",
      "coexistence": "new service + WebSphere consume same MQ reply queue (correlation id)"
    },
    {
      "id": "INT-002",
      "name": "Statement PDF rendering",
      "functional_categories": [
        "data_pipeline",
        "app_to_app_internal"
      ],
      "current_state": {
        "Protocol": "batch",
        "Transport": "nightly batch render to NAS",
        "Auth": "n/a (internal)",
        "Payload": "AFP -> PDF",
        "Stack": "on-prem batch (Java + AFP toolkit)",
        "SLA": "nightly, 2M docs",
        "Criticality": "Tier 2",
        "Failure today": "rerun window; ops paged"
      },
      "target_intent": {
        "Preserve": "byte-equivalent PDF output, same archive path",
        "Downtime": "1 window",
        "Regression": "none",
        "Reject": "no change to archive retention"
      },
      "dependencies": "after INT-001",
      "r_factor": "Refactor",
      "cutover_strategy": "Dual-run",
      "validation_gates": "5-night checksum match; PDF visual-diff < 0.01%",
      "coexistence": "archive ingests from one pipeline per night"
    },
    {
      "id": "INT-003",
      "name": "Payment posting + fraud (cross-cloud)",
      "functional_categories": [
        "app_to_app_external",
        "app_to_app_cross_cloud",
        "sync_request_response"
      ],
      "current_state": {
        "Protocol": "HTTPS REST",
        "Auth": "mTLS to on-prem fraud engine",
        "Payload": "/docs/post-v1.openapi.yaml",
        "Stack": "WebSphere REST + fraud SDK",
        "SLA": "p95 < 900ms, 50 RPS peak",
        "Criticality": "Tier 1",
        "Failure today": "fail-closed -> hold for manual review"
      },
      "target_intent": {
        "Preserve": "same posting contract, same fail-closed rule, same score thresholds",
        "Downtime": "0 min",
        "Regression": "+110ms p95 cross-cloud",
        "Reject": "no AWS API Gateway; fraud stays GCP"
      },
      "dependencies": "independent after Apigee provisioned",
      "r_factor": "Replatform",
      "cutover_strategy": "Blue-green",
      "validation_gates": "parity validator (shadow 14 days, decision diff < 0.05%); latency <= +110ms",
      "cross_cloud": {
        "Source": "on-prem fraud engine, DC-East",
        "Target": "GCP Apigee enterprise-apigee-prod -> fraud scoring",
        "Latency budget": "110ms p95 added",
        "Transit": "AWS PrivateLink -> GCP PSC -> Apigee (per ADR-019)"
      },
      "coexistence": "on-prem + GCP fraud parallel; single decision ledger"
    },
    {
      "id": "INT-004",
      "name": "Posting notifications",
      "functional_categories": [
        "app_to_app_internal",
        "event_driven_async"
      ],
      "current_state": {
        "Protocol": "JMS",
        "Transport": "IBM MQ (POST.NOTIFY)",
        "Auth": "TLS + channel cert",
        "Payload": "/docs/post-notify-v1.json",
        "Stack": "WebSphere JMS",
        "SLA": "1000 msg/min, 8000/min peak",
        "Criticality": "Tier 1",
        "Failure today": "backoff; spill to file"
      },
      "target_intent": {
        "Preserve": "at-least-once, contract unchanged",
        "Downtime": "0 min",
        "Regression": "none",
        "Reject": "no SNS (point-to-point downstream)"
      },
      "dependencies": "after INT-003",
      "r_factor": "Refactor",
      "cutover_strategy": "Dual-publish",
      "validation_gates": "24h load test; SQS publish p95 < 50ms",
      "coexistence": "downstream dedupe by event_id (per ADR-630)"
    }
  ],
  "services": [
    {
      "name": "payments-statements-statement-retrieval-api",
