      "current_state": {
        "Protocol": "MQ (JMS)",
        "Transport": "IBM MQ to mainframe CICS (LOAN.BOOK.REQ)",
        "Auth": "TLS + channel cert",
        "Payload": "fixed-format copybook",
        "Stack": "Spring JMS + MQ client 9.x",
        "SLA": "200 msg/min, 2000/min peak",
        "Criticality": "Tier 1",
        "Failure today": "spill-to-file + replay; ops paged"
      },
      "target_intent": {
        "Preserve": "exact copybook contract, at-least-once, ordering per account",
        "Downtime": "0 min (dual-publish)",
        "Regression": "none",
        "Reject": "no mainframe changes (out of scope - Retain)"
      },
      "dependencies": "after INT-002",
      "r_factor": "Retain",
      "cutover_strategy": "Dual-publish",
      "validation_gates": "72h soak; copybook byte-parity 100%; zero dropped bookings",
      "coexistence": "mainframe consumes from one publisher; dedupe by request_id"
    }
