{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ingest_epic_result",
  "description": "Retrieve the signal-bearing spec.md + Epic Signal Ledger + per-section confidence. The prompt file writes spec.md and epic-signal-ledger.json to the workspace.",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "required": [
        "taskId"
      ],
      "properties": {
        "taskId": {
          "type": "string"
        }
      }
    },
    "output": {
      "type": "object",
      "required": [
        "spec_md",
        "epic_signal_ledger",
        "per_section_confidence"
      ],
      "properties": {
        "spec_md": {
          "type": "string",
          "description": "10-section signal-bearing spec.md with a Rally provenance header"
        },
        "epic_signal_ledger": {
          "$ref": "epic-signal-ledger.schema.json"
        },
        "per_section_confidence": {
          "type": "object",
          "description": "Per-section signal-slot fill ratio (deterministic; not an LLM self-assessment).",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "provenance": {
          "type": "object",
          "properties": {
            "source": {
              "type": "string",
              "enum": [
                "rally"
              ]
            },
            "formatted_id": {
              "type": "string"
            },
            "object_version": {
              "type": [
                "integer",
                "null"
              ]
            },
            "last_update_date": {
              "type": "string"
            }
          }
        },
        "blueprint_gate": {
          "type": "object",
          "description": "Step-0 validate_spec verdict for the produced spec (H-3 reconciliation): whether the ingested spec will pass the blueprint quality gate, and any section with high fill-ratio confidence that is nonetheless gated.",
          "properties": {
            "quality_score": {
              "type": "number"
            },
            "blocked": {
              "type": "boolean"
            },
            "findings": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "section": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  }
                }
              }
            },
            "high_confidence_but_gated": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
