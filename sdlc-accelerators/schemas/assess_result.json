{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "assess_result",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "required": [
        "taskId"
      ],
      "properties": {
        "taskId": {
          "type": "string"
        }
      }
    },
    "output": {
      "type": "object",
      "required": [
        "scorecard",
        "findings"
      ],
      "properties": {
        "scorecard": {
          "type": "object",
          "properties": {
            "overall": {
              "type": "number"
            },
            "per_section": {
              "type": "object"
            }
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "severity",
              "classification"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "severity": {
                "type": "string",
                "enum": [
                  "critical",
                  "high",
                  "medium",
                  "low"
                ]
              },
              "classification": {
                "type": "string",
                "enum": [
                  "showstopper",
                  "tech_debt"
                ]
              },
              "section": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}