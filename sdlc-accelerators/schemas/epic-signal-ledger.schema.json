{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "epic-signal-ledger.schema.json",
  "title": "Epic Signal Ledger",
  "description": "Section-keyed, span-traced ledger produced by Phase A (agentic shaping) and consumed by Phase B (deterministic mapping) of /accelerator.ingest-epic. SDLC Accelerators IP -- section-keyed (NOT the external platform requirement-objects); confidence is a deterministic fill ratio (NOT agent-reported).",
  "type": "object",
  "required": ["schema", "provenance", "sections"],
  "properties": {
    "schema": { "type": "string", "const": "epic-signal-ledger/v1" },
    "provenance": {
      "type": "object",
      "required": ["source", "formatted_id"],
      "properties": {
        "source": { "type": "string", "enum": ["rally"] },
        "formatted_id": { "type": "string" },
        "object_version": { "type": ["integer", "null"], "description": "Rally ObjectVersion; refresh compares this against Rally to detect epic drift" },
        "last_update_date": { "type": "string" }
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["num", "key", "title", "expected_slots", "filled", "confidence", "signals"],
        "properties": {
          "num": { "type": "integer", "minimum": 1, "maximum": 10 },
          "key": { "type": "string" },
          "title": { "type": "string" },
          "expected_slots": { "type": "integer", "minimum": 0 },
          "filled": { "type": "integer", "minimum": 0 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "min(1, filled/expected_slots)" },
          "needs_review": { "type": "boolean" },
          "optional": { "type": "boolean" },
          "signals": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["value", "kind", "epic_span"],
              "properties": {
                "value": { "type": "string", "description": "Normalized signal text for the spec" },
                "kind": { "type": "string" },
                "epic_span": { "type": "string", "description": "VERBATIM substring of the Epic -- the extractive guarantee; signals whose span is not found in the Epic are dropped" }
              }
            }
          }
        }
      }
    }
  }
}
