{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "recordTechDebt",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "required": [
        "findings"
      ],
      "properties": {
        "findings": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "output": {
      "type": "object",
      "required": [
        "signal"
      ],
      "properties": {
        "signal": {
          "type": "string",
          "enum": [
            "resume",
            "stop"
          ]
        },
        "tech_debt_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}