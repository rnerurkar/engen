{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ingest_epic_start",
  "description": "Async. OPTIONAL Greenfield front door. Starts the two-phase Epic-to-Spec ingestion (Phase A agentic shaping -> Phase B deterministic mapping). Input is Rally Epic CONTENT only -- never credentials (the coding agent fetched it client-side via the Rally MCP server using Entra ID SSO).",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "required": ["epic"],
      "properties": {
        "epic": {
          "type": "object",
          "description": "Rally Epic content fetched client-side.",
          "required": ["formatted_id"],
          "properties": {
            "formatted_id": { "type": "string", "description": "Rally Epic FormattedID, e.g. E1234" },
            "name": { "type": "string" },
            "description": { "type": "string" },
            "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
            "nfrs": { "type": "array", "items": { "type": "string" } },
            "dependencies": { "type": "array", "items": { "type": "string" } },
            "linked_items": { "type": "array", "items": { "type": "string" } },
            "object_version": { "type": "integer", "description": "Rally ObjectVersion (source-version-token for drift detection)" },
            "last_update_date": { "type": "string" }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["taskId", "pollInterval"],
      "properties": {
        "taskId": { "type": "string" },
        "pollInterval": { "type": "integer", "description": "seconds" },
        "status": { "type": "string", "enum": ["queued"] }
      }
    }
  }
}
