{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "blueprint_status",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "required": [
        "taskId"
      ],
      "properties": {
        "taskId": {
          "type": "string"
        }
      }
    },
    "output": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "queued",
            "running",
            "completed",
            "failed"
          ]
        },
        "stage": {
          "type": "string"
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}