"""MCP client wiring. Generated by SDLC Accelerators (agentic-ai-adk domain skill).
One MCPToolset per mcp_server tool binding.
"""
from google.adk.tools.mcp_tool import MCPToolset, StdioConnectionParams

_TOOLSETS = {
{% for tb in tool_bindings if tb.type == "mcp_server" %}    "{{ tb.name }}": MCPToolset(
        connection_params=StdioConnectionParams(
            url="{{ tb.endpoint }}",
            auth="{{ tb.auth_method }}",
        ),
    ),
{% endfor %}}


def get_mcp_toolset(name: str) -> MCPToolset:
    return _TOOLSETS[name]
