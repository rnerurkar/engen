"""Inner-loop evaluation hook — runs on every `git commit` (wired via .pre-commit-config.yaml).

Runs 5-10 evalsets locally via the Vertex AI Evaluation SDK (<60s) and validates the golden
dataset quality gate. Exits non-zero to BLOCK the commit if any metric regresses >10% or the
dataset fails the quality thresholds. Generated by SDLC Accelerators (EvalOps inner loop).
"""
from __future__ import annotations
import json
import sys
from pathlib import Path

GOLDEN = Path("eval/golden-dataset.json")
BASELINE = Path("eval/baseline_scores.json")
REGRESSION_THRESHOLD = 0.10  # block if any metric drops >10%

# Golden dataset quality gate (constitution-enforced minimums)
MIN_ENTRIES_PER_AGENT = 10
MIN_EDGE_CASES = 3
MIN_NEGATIVE_TESTS = 1


def _fail(msg: str) -> None:
    print(f"❌ Inner-loop eval failed: {msg}", file=sys.stderr)
    sys.exit(1)


def check_golden_dataset() -> dict:
    if not GOLDEN.exists():
        _fail("eval/golden-dataset.json missing. See Developer Guide, Section 4b.")
    data = json.loads(GOLDEN.read_text())
    entries = data.get("entries", [])
    agents = {e.get("agent") for e in entries if e.get("agent")}
    for agent in agents:
        n = sum(1 for e in entries if e.get("agent") == agent)
        if n < MIN_ENTRIES_PER_AGENT:
            _fail(f"agent '{agent}' has {n} entries (need >= {MIN_ENTRIES_PER_AGENT}). "
                  "Add more before committing. See Developer Guide, Section 4b.")
    if sum(1 for e in entries if e.get("edge_case")) < MIN_EDGE_CASES:
        _fail(f"need >= {MIN_EDGE_CASES} edge-case entries.")
    if sum(1 for e in entries if e.get("expect_failure")) < MIN_NEGATIVE_TESTS:
        _fail(f"need >= {MIN_NEGATIVE_TESTS} negative test (expected failure).")
    return data


def run_evalsets(dataset: dict) -> dict:
    """Run the evalsets via the Vertex AI Evaluation SDK.
    TODO(live): call the Vertex AI Evaluation SDK over the golden dataset and return metric scores.
    The gate logic (regression check below) is real; the SDK call is the seam."""
    raise NotImplementedError(
        "Wire the Vertex AI Evaluation SDK: run evalsets over eval/golden-dataset.json, "
        "return {metric: score}. The regression-gate logic is ready."
    )


def check_regression(scores: dict) -> None:
    if not BASELINE.exists():
        return  # first run establishes the baseline
    baseline = json.loads(BASELINE.read_text())
    for metric, score in scores.items():
        base = baseline.get(metric)
        if base is not None and score < base - REGRESSION_THRESHOLD:
            _fail(f"metric '{metric}' regressed {base:.2f} -> {score:.2f} "
                  f"(> {REGRESSION_THRESHOLD:.0%}). Fix before committing.")


def main() -> int:
    dataset = check_golden_dataset()      # quality gate (deterministic)
    scores = run_evalsets(dataset)        # Vertex AI Eval SDK (seam)
    check_regression(scores)              # regression gate (deterministic)
    print("✅ Inner-loop eval passed.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
