# Generated by SDLC Accelerators (constitution Rule 11 — always generate pre-commit hooks).
# Install once per clone: `pip install pre-commit && pre-commit install`.
# After that, every `git commit` (terminal OR VS Code Source Control) runs these hooks and
# BLOCKS the commit if any fail.
repos:
  # --- Linting (ruff) ---
  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.6.9
    hooks:
      - id: ruff                # lint
        args: [--fix]
      - id: ruff-format         # format

  # --- Inner-loop evaluation gate ---
  # Runs 5-10 evalsets locally via the Vertex AI Evaluation SDK in <60s.
  # Blocks the commit if any metric regresses >10% or the golden-dataset quality gate fails
  # (>=10 entries/agent, >=3 edge cases, >=1 negative test, 100% agent coverage).
  - repo: local
    hooks:
      - id: inner-loop-eval
        name: SDLC Accelerators inner-loop evaluation
        entry: python tests/eval_inner_loop.py
        language: system
        pass_filenames: false
        always_run: true
        stages: [commit]
