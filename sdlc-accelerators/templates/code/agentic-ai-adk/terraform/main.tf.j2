# Terraform for {{ metadata.solution_id }}
# Generated by SDLC Accelerators (agentic-ai-adk domain skill).
# Constitution Rule 4: company modules ONLY — never raw google_*/aws_* resources.
# Constitution Rules 8-10: VPC-SC + CMEK + per-agent Workload Identity enforced by the modules.

terraform {
  required_version = ">= 1.5"
  required_providers {
    google = { source = "hashicorp/google", version = "~> 5.0" }
  }
}

variable "project_id" { type = string }
variable "env"        { type = string }

{% for m in infra_modules %}
module "{{ m.module | replace('-', '_') }}" {
  source  = "{{ m.source }}"
  version = "{{ m.version }}"
{% for k, v in m.variables.items() %}  {{ k }} = {% if v is string %}"{{ v }}"{% else %}{{ v }}{% endif %}
{% endfor %}}
{% endfor %}
