# Per-agent Workload Identity service accounts.
# Constitution Rule 10: each agent gets ONLY the bindings for its assigned tools.
# Orchestrators (delegation-only) get NO direct data access.
# Generated by SDLC Accelerators (agentic-ai-adk domain skill).

{% for ai in agent_identity_config %}
# {{ ai.agent }}{% if "delegation-only" in ai.capabilities %} (orchestrator — delegation only, no data access){% endif %}

module "sa_{{ ai.agent }}" {
  source  = "github.com/company/tf-agent-identity"
  version = "v1.2.0"

  account_id   = "sa-{{ ai.agent | replace('_', '-') }}"
  display_name = "Agent SA — {{ ai.agent }}"
  project_id   = var.project_id

  # Least-privilege capabilities (empty for delegation-only orchestrators).
  capabilities = [
{% for cap in ai.capabilities %}{% if cap != "delegation-only" %}    "{{ cap }}",
{% endif %}{% endfor %}  ]

  # Explicitly denied tool bindings (defense in depth).
  denied_tools = [
{% for d in ai.denied %}    "{{ d }}",
{% endfor %}  ]
}
{% endfor %}
