  "sequence_summary": [
    "Customer submits claim \u2192 fnol_coordinator receives inbound claim via Apigee Gateway",
    "fnol_coordinator \u2192 extract_details extracts claimant info from claims-db-mcp",
    "fnol_coordinator \u2192 parallel_enrichment fans out to 3 sources in parallel",
    "enrich_policy queries policy-api-mcp | enrich_vehicle queries vehicle-api-mcp | enrich_weather queries weather-api-mcp (each with LoopAgent retry, max 3 attempts)",
    "parallel_enrichment consolidates \u2192 returns enriched_claim to fnol_coordinator",
    "fnol_coordinator \u2192 severity_classifier applies business rules (severity_classifier_fn)",
    "IF severity \u2265 critical AND damage_estimate > $10K \u2192 severity_classifier delegates to body-shop-a2a via A2A for estimate",
    "IF severity = critical OR high \u2192 fnol_coordinator routes to human_review via review-queue-mcp",
    "fnol_coordinator returns claim confirmation to customer via Apigee Gateway"
  ],
  "business_rules": [
    {
      "id": "BR-001",
      "source": "spec \u00a77",
      "rule": "IF damage_description CONTAINS 'total loss' OR damage_estimate > $15,000 THEN severity = 'critical'",
      "implemented_by": "severity_classifier_fn"
    },
    {
      "id": "BR-002",
      "source": "spec \u00a77",
      "rule": "IF injuries_reported = true THEN severity = MIN('high', current_severity)",
      "implemented_by": "severity_classifier_fn"
    },
    {
      "id": "BR-003",
      "source": "spec \u00a77",
      "rule": "IF police_report_filed = false AND damage_estimate > $5,000 THEN flag = 'fraud_review'",
      "implemented_by": "severity_classifier_fn"
    },
    {
      "id": "BR-004",
      "source": "spec \u00a77",
      "rule": "IF severity IN ('critical', 'high') THEN route_to_human = true",
      "implemented_by": "fnol_coordinator (conditional step 4)"
    },
    {
      "id": "BR-005",
      "source": "spec \u00a77",
      "rule": "IF severity >= 'critical' AND damage_estimate > $10,000 THEN delegate_body_shop = true",
      "implemented_by": "severity_classifier (A2A delegation to body-shop-a2a)"
    }
  ],
