"""Cutover gate for {{ integration_id }} — {{ name }}.
Guarded switch from legacy to target with a rollback SLA. Generated by SDLC Accelerators.
Rollback: {{ rollback_path }}.
"""
import logging
logger = logging.getLogger("migration.{{ integration_id }}")


def cutover(preconditions, switch_fn):
    """Execute cutover only if all preconditions (health checks, soak complete) pass."""
    if not all(preconditions.values()):
        failed = [k for k, v in preconditions.items() if not v]
        logger.error("cutover_blocked", extra={"integration": "{{ integration_id }}", "failed": failed})
        raise RuntimeError(f"cutover blocked: {failed}")
    switch_fn()
    logger.info("cutover_done", extra={"integration": "{{ integration_id }}"})


def rollback(switch_back_fn):
    """Rollback path: {{ rollback_path }}."""
    switch_back_fn()
    logger.warning("rollback", extra={"integration": "{{ integration_id }}", "action": "switched_back"})
