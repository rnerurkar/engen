"""Strangler-Fig proxy for {{ integration_id }} — {{ name }}.
Routes traffic between the legacy ({{ source }}) and target ({{ target }}) behind a feature flag.
Rollback: {{ rollback_path }}. Generated by SDLC Accelerators brownfield skill.
"""
import logging
logger = logging.getLogger("migration.{{ integration_id }}")

FEATURE_FLAG = "{{ integration_id }}_use_target"   # flip to route to target; flip back to roll back


def route(request, flags, legacy_handler, target_handler):
    """Route to target when the flag is on, else legacy. Emits coexistence telemetry."""
    use_target = flags.get(FEATURE_FLAG, False)
    handler = target_handler if use_target else legacy_handler
    logger.info("coexistence", extra={"integration": "{{ integration_id }}",
                                      "route": "target" if use_target else "legacy"})
    return handler(request)


def rollback(flags):
    """Rollback path: {{ rollback_path }}."""
    flags[FEATURE_FLAG] = False
    logger.warning("rollback", extra={"integration": "{{ integration_id }}", "action": "flag_off"})
