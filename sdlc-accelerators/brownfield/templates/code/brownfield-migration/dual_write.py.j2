"""Dual-write window for {{ integration_id }} — {{ name }}.
Publishes to legacy ({{ source }}) AND target ({{ target }}) during the coexistence window
({{ coexistence_window }}). Legacy remains source of truth until cutover.
Rollback: {{ rollback_path }}. Generated by SDLC Accelerators brownfield skill.
"""
import logging
logger = logging.getLogger("migration.{{ integration_id }}")


def publish(message, legacy_publish, target_publish, idempotency_key):
    """Dual-publish. Legacy is authoritative; target receives a copy keyed for idempotency."""
    legacy_publish(message)
    try:
        target_publish(message, idempotency_key=idempotency_key)
        logger.info("dual_write_ok", extra={"integration": "{{ integration_id }}", "key": idempotency_key})
    except Exception as e:
        # Target failure must NOT break legacy (source of truth). Telemetry for reconciliation.
        logger.error("dual_write_target_failed", extra={"integration": "{{ integration_id }}", "error": str(e)})


def rollback(config):
    """Rollback path: {{ rollback_path }}. Disable target publish; legacy continues."""
    config["{{ integration_id }}_target_enabled"] = False
    logger.warning("rollback", extra={"integration": "{{ integration_id }}", "action": "target_disabled"})
