{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SDLC Accelerators Brownfield Design Contract",
  "description": "Brownfield (CSA->TSA) design contract v2.0. A governance artifact, NOT an AgentForge signed Design Contract.",
  "type": "object",
  "required": ["schema_version", "lifecycle", "generated_at", "tech_substitutions", "pattern_selections", "migration_phases"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "lifecycle": {"enum": ["DRAFT", "LIVE", "STALE", "REFRESHED"]},
    "generated_at": {"type": "string", "format": "date-time"},
    "last_refreshed_at": {"type": "string", "format": "date-time"},
    "migration_readiness_score": {"type": "integer", "minimum": 0, "maximum": 100},
    "tech_substitutions": {
      "type": "array",
      "items": {"$ref": "tech-substitution-row.schema.json"}
    },
    "pattern_selections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["integration_id", "pattern_ref", "confidence"],
        "properties": {
          "integration_id": {"type": "string"},
          "pattern_ref": {"type": "string"},
          "functional_category": {"type": "array", "items": {"type": "string"}},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "requires_review": {"type": "boolean"}
        }
      }
    },
    "attested_adrs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["integration_id", "adr_id", "result"],
        "properties": {
          "integration_id": {"type": "string"},
          "adr_id": {"type": "string"},
          "result": {"enum": ["pass", "flag", "reject"]}
        }
      }
    },
    "migration_phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "integration_ids"],
        "properties": {
          "phase": {"type": "integer"},
          "name": {"type": "string"},
          "integration_ids": {"type": "array", "items": {"type": "string"}},
          "coexistence": {"enum": ["dual-read", "dual-write", "hard-cutover", "none"]},
          "cross_cloud_coordination": {"type": "boolean"},
          "rollback_sla_minutes": {"type": "integer"}
        }
      }
    },
    "cutover_strategy": {"type": "string"},
    "staleness_triggers": {
      "type": "object",
      "properties": {
        "adr_store_version": {"type": "string"},
        "substitution_table_version": {"type": "string"},
        "iac_manifest_version": {"type": "string"}
      }
    }
  }
}
